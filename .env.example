# ==============================================================================
# CONFIGURAÇÃO DE VARIÁVEIS DE AMBIENTE - GUARDIÃO DA REDE
# ==============================================================================
# Renomeie este arquivo para .env no seu ambiente local ou configure estas
# variáveis de ambiente na plataforma de hospedagem (Render, Fly.io, Vercel).
# ATENÇÃO: Nunca envie chaves de API reais para o GitHub.

# 1. GOOGLE GEMINI API KEY (Usada no site frontend para análise de IA em tempo real)
# Obtenha uma chave gratuita seguindo estes passos:
# - Acesse: https://aistudio.google.com/
# - Faça login com sua conta do Google.
# - Clique em "Get API key" no menu lateral.
# - Clique em "Create API key" e copie a chave gerada (inicia com AIzaSy...).
# - O plano gratuito do Gemini permite até 60 requisições por minuto sem custos.
GEMINI_API_KEY=sua_chave_do_google_gemini_aqui

# 2. TELEGRAM BOT TOKEN (Usado para o chatbot no Telegram)
# Obtenha um token de bot seguindo estes passos:
# - Abra o Telegram e procure pelo bot oficial: @BotFather (https://t.me/BotFather)
# - Inicie uma conversa e envie o comando: /newbot
# - Insira um nome de exibição para o seu bot (Ex: GuardiaoDaRedeBot).
# - Defina um username único terminando em "bot" (Ex: guardiao_rede_fib16_bot).
# - Copie o token HTTP API gerado (Ex: 123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ).
TELEGRAM_BOT_TOKEN=seu_token_do_telegram_bot_aqui
